{
  "name": "vscode-window-flash-notify-relay",
  "displayName": "Window Flash Notify Relay",
  "description": "%extension.description%",
  "version": "0.2.24",
  "publisher": "qqqasdwx",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qqqasdwx/vscode-window-flash-notify.git"
  },
  "bugs": {
    "url": "https://github.com/qqqasdwx/vscode-window-flash-notify/issues"
  },
  "homepage": "https://github.com/qqqasdwx/vscode-window-flash-notify#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "notification",
    "taskbar",
    "flash",
    "remote",
    "ssh",
    "vagrant",
    "hook",
    "relay"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:windowFlashNotifyRelay.copyCurlCommand",
    "onCommand:windowFlashNotifyRelay.testFlash"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "windowFlashNotifyRelay.copyCurlCommand",
        "title": "%command.copyCurlCommand.title%"
      },
      {
        "command": "windowFlashNotifyRelay.testFlash",
        "title": "%command.testFlash.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "windowFlashNotifyRelay.basePort": {
          "type": "number",
          "default": 7531,
          "minimum": 1024,
          "maximum": 65535,
          "description": "%configuration.basePort.description%"
        },
        "windowFlashNotifyRelay.portSearchRange": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "%configuration.portSearchRange.description%"
        },
        "windowFlashNotifyRelay.listenHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "%configuration.listenHost.description%"
        },
        "windowFlashNotifyRelay.authToken": {
          "type": "string",
          "default": "",
          "description": "%configuration.authToken.description%"
        }
      }
    }
  }
}
